void vTask1_ReadSensor(void *params)
{
    uint16_t lux;

    while(1)
    {
        if(sensor_enable)
        {
            lux = Read_Sensor();

            current_sensor_value = lux;

            xQueueOverwrite(
                    sensor_queue,
                    &lux);
        }

        vTaskDelay(
                pdMS_TO_TICKS(100));
    }
}

void vTask2_Display(void *params)
{
    uint16_t lux;
    char msg[50];

    while(1)
    {
        xQueuePeek(
                sensor_queue,
                &lux,
                portMAX_DELAY);

        sprintf(msg,
                "Light = %u\r\n",
                lux);

        print_msg(msg);

        vTaskDelay(
                pdMS_TO_TICKS(1000));
    }
}
void vTask3_Command(void *params)
{
    while(1)
    {
        if(command_buffer[0] == '1')
        {
            sensor_enable = 1;
        }
        else if(command_buffer[0] == '2')
        {
            sensor_enable = 0;
        }
        else if(command_buffer[0] == '3')
        {
            char msg[50];

            sprintf(msg,
                    "Sensor=%s Value=%u\r\n",
                    sensor_enable ?
                    "RUNNING" :
                    "STOPPED",
                    current_sensor_value);

            print_msg(msg);
        }

        vTaskDelay(
                pdMS_TO_TICKS(100));
    }
}
void USART2_IRQHandler(void){
	 BaseType_t xHigherPriorityTaskWoken = pdFALSE;
	uint8_t data_byte;
	 if (__HAL_UART_GET_FLAG(&huart2,  UART_FLAG_RXNE ) == SET){
		 //a data byte is received from the user
		 data_byte = (uint8_t)(USART2->RDR);
		 command_buffer[command_len++] = data_byte & 0xFF;

		 if(data_byte == '\r'){
			 command_len = 0;
			 //user is finished entering data,
			 xTaskNotifyFromISR(xCmdTaskHandle,0,eNoAction,&xHigherPriorityTaskWoken);

//			 portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
		 }
	 }
	 // if the above freertos apis wake up any higher priority taks , then yield the processor
	 // to the higher priority task which is just woken up
	 portYIELD_FROM_ISR(xHigherPriorityTaskWoken);
}

